@model QLTaiChinh.Models.DangKyViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome Back - Login Template</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: #f8f9fa;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .login-card {
            background: #ffffff;
            padding: 40px;
            border-radius: 8px;
            border: 1px solid #e0e0e0;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }

        .header {
            margin-bottom: 32px;
        }

            .header p {
                color: #667085;
                font-size: 14px;
                margin-bottom: 8px;
            }

            .header h1 {
                color: #1d2939;
                font-size: 32px;
                font-weight: 700;
            }

        .form-group {
            margin-bottom: 20px;
        }

        input[type="email"],
        input[type="password"],
        input[type="text"] {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #d0d5dd;
            border-radius: 8px;
            font-size: 16px;
            outline: none;
            transition: border-color 0.2s;
        }

        input:focus {
            border-color: #4482ff;
        }

        .options-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            font-size: 14px;
        }

        .remember-me {
            display: flex;
            align-items: center;
            color: #344054;
            cursor: pointer;
        }

            .remember-me input {
                margin-right: 8px;
                width: 16px;
                height: 16px;
            }

        .forgot-password {
            color: #4482ff;
            text-decoration: none;
            font-weight: 500;
        }

        .btn {
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: 0.3s;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .btn-primary {
            background-color: #4482ff;
            color: white;
            margin-bottom: 16px;
        }

            .btn-primary:hover {
                background-color: #3366cc;
            }

        .btn-google {
            background-color: white;
            color: #344054;
            border: 1px solid #d0d5dd;
        }

            .btn-google:hover {
                background-color: #f9fafb;
            }

            .btn-google img {
                width: 20px;
            }

        .footer-text {
            text-align: center;
            margin-top: 24px;
            font-size: 14px;
            color: #667085;
        }

            .footer-text a {
                color: #4482ff;
                text-decoration: none;
                font-weight: 600;
            }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="header">
            <h1>ĐĂNG KÝ</h1>
            <p>Hãy nhập đầy đủ thông tin</p>
        </div>

        <form asp-action="Register" method="post">
            <div class="form-group">
                <input asp-for="HoTen" type="text" placeholder="Họ tên " required>
                <span asp-validation-for="HoTen" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input asp-for="Email" type="email" placeholder="Email " required>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input asp-for="Password" type="password" placeholder="Mật khẩu" required>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input asp-for="ConfimPW" type="password" placeholder="Nhập lại mật khẩu" required>
                <span asp-validation-for="ConfimPW" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Đăng ký</button>
        </form>
    </div>
</body>
</html>
