@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FinanceControl - Quản lý tài chính thông minh</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --primary-blue: #4482ff; }
        body { font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
        .navbar-brand { font-weight: 700; color: var(--primary-blue) !sourcet; }
        .hero-section { padding: 100px 0; background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); }
        .feature-icon { font-size: 2.5rem; color: var(--primary-blue); margin-bottom: 1.5rem; }
        .section-padding { padding: 80px 0; }
        .footer { background: #1d2939; color: white; padding: 40px 0; }

        .alert {
            display: none;
        }

            .alert.show {
                display: block;
            }

            .alert.success {
                color: green;
            }

            .alert.error {
                color: red;
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="#home">FINANCE APP</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-outline-primary" asp-action="Login" asp-controller="Login">Đăng nhập</a>
                        <a class="btn btn-primary" asp-action="Register" asp-controller="Register">Đăng ký</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <section id="home" class="hero-section">
        <div class="container text-center">
            <h1 class="display-4 fw-bold mb-4">Làm chủ tài chính, Hướng tới tương lai</h1>
            <p class="lead mb-5 px-md-5">Giải pháp giúp bạn theo dõi thu nhập, chi tiêu một cách khoa học, minh bạch và hiệu quả trên nền tảng Web.</p>
        </div>
    </section>

    <section id="about" class="section-padding">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="fw-bold">Tại sao nên chọn chúng tôi?</h2>
                <p class="text-muted">Chúng tôi cung cấp các công cụ mạnh mẽ để bạn kiểm soát dòng tiền của mình.</p>
            </div>
            <div class="row g-4 text-center">
                <div class="col-md-4">
                    <i class="fa-solid fa-list-check feature-icon"></i>
                    <h4>Phân loại giao dịch</h4>
                    <p class="text-muted">Tự động hóa việc ghi chép và phân loại giao dịch theo từng danh mục cụ thể.</p>
                </div>
                <div class="col-md-4">
                    <i class="fa-solid fa-chart-line feature-icon"></i>
                    <h4>Báo cáo trực quan</h4>
                    <p class="text-muted">Cung cấp biểu đồ trực quan (cột, tròn, đường) giúp bạn phân tích xu hướng chi tiêu.</p>
                </div>
                <div class="col-md-4">
                    <i class="fa-solid fa-bell feature-icon"></i>
                    <h4>Cảnh báo ngân sách</h4>
                    <p class="text-muted">Nhận thông báo kịp thời khi chi tiêu vượt quá hạn mức ngân sách đã đặt ra.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="section-padding bg-light">
        <div class="container">
            <div class="row">
                <div class="col-lg-6">
                    <h2 class="fw-bold mb-4">Liên hệ với chúng tôi</h2>
                    <p>Mọi thắc mắc về hệ thống quản lý tài chính cá nhân, vui lòng gửi tin nhắn cho chúng tôi.</p>
                    <ul class="list-unstyled mt-4">
                        <li><i class="fa-solid fa-location-dot text-primary me-2"></i> Trường Đại học Nam Cần Thơ</li>
                        <li><i class="fa-solid fa-envelope text-primary me-2"></i> vitran8605@gmail.com</li>
                        <li><i class="fa-solid fa-user-graduate text-primary me-2"></i> Sinh viên: Phạm Trần Tuấn Vĩ</li>
                    </ul>
                </div>
                <div class="col-lg-6">
                    <div class="card p-4 shadow-sm">
                        <div id="alertBox" class="alert" style="display:none;"></div>
                        <form onsubmit="handleSubmit(event)">
                            <div class="mb-3">
                                <label class="form-label">Họ tên</label>
                                <input type="text" name="from_name" class="form-control" placeholder="Nhập tên của bạn">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" name="from_email" class="form-control" placeholder="Email liên hệ">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Lời nhắn</label>
                                <textarea class="form-control" name="message" rows="4" placeholder="Chúng tôi có thể giúp gì cho bạn?"></textarea>
                            </div>
                            <button type="submit" id="submitBtn" class="btn btn-primary w-100">Gửi lời nhắn</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="footer text-center">
        <div class="container">
            <p class="mb-0">&copy; 2026 Hệ thống Quản lý Tài chính Cá nhân. Đề tài Khoa học & Công nghệ cấp cơ sở.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@@emailjs/browser@4/dist/email.min.js"></script>
    <script>
        // ========================================
        // CẤU HÌNH EMAILJS
        // ========================================
                const EMAILJS_CONFIG = {
                    publicKey: "ItetbIJtLG7JeqUJg",
                    serviceId: "service_s25csgh",
                    templateId: "template_6kgk8de"
                };

                // Khởi tạo EmailJS
                (function() {
                    emailjs.init(EMAILJS_CONFIG.publicKey);
                })();

                // ========================================
                // XỬ LÝ FORM SUBMISSION
                // ========================================
                function handleSubmit(event) {
                    event.preventDefault();

                    const submitButton = document.getElementById('submitBtn');
                    const alertBox = document.getElementById('alertBox');
                    const form = event.target;

                    // Hiển thị trạng thái đang gửi
                    submitButton.textContent = 'Đang gửi...';
                    submitButton.disabled = true;
                    alertBox.classList.remove('show', 'success', 'error');

                    // Lấy dữ liệu từ form
                    const templateParams = {
                        from_name: form.from_name.value,
                        from_email: form.from_email.value,
                        message: form.message.value,
                        to_name: 'Phạm Trần Tuấn Vĩ'
                    };

                    // Gửi email qua EmailJS
                    emailjs.send(
                        EMAILJS_CONFIG.serviceId,
                        EMAILJS_CONFIG.templateId,
                        templateParams
                    )
                    .then(function(response) {
                        console.log('✅ Email sent successfully!', response.status, response.text);

                        // Hiển thị thông báo thành công
                        alertBox.textContent = '✅ Cảm ơn bạn đã liên hệ! Tin nhắn đã được gửi thành công.';
                        alertBox.classList.add('show', 'success');

                        // Reset form
                        form.reset();

                        // Ẩn thông báo sau 5 giây
                        setTimeout(() => {
                            alertBox.classList.remove('show');
                        }, 5000);

                    }, function(error) {
                        console.error('❌ Email sending failed:', error);

                        // Hiển thị thông báo lỗi
                        let errorMessage = '❌ Có lỗi xảy ra khi gửi tin nhắn. ';

                        if (error.text && error.text.includes('publicKey')) {
                            errorMessage += 'Vui lòng cấu hình EmailJS Public Key.';
                        } else if (error.text && error.text.includes('Service ID')) {
                            errorMessage += 'Service ID không hợp lệ.';
                        } else if (error.text && error.text.includes('Template ID')) {
                            errorMessage += 'Template ID không hợp lệ.';
                        } else {
                            errorMessage += 'Vui lòng thử lại sau. Chi tiết: ' + (error.text || error.message || 'Unknown error');
                        }

                        alertBox.textContent = errorMessage;
                        alertBox.classList.add('show', 'error');

                        // Ẩn thông báo sau 7 giây
                        setTimeout(() => {
                            alertBox.classList.remove('show');
                        }, 7000);
                    })
                    .finally(function() {
                        // Khôi phục trạng thái button
                        submitButton.textContent = 'Gửi Tin Nhắn';
                        submitButton.disabled = false;
                    });
                }
        // ========================================
        // SMOOTH SCROLLING
        // ========================================
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // ========================================
        // ANIMATE SKILL BARS ON SCROLL
        // ========================================
        const observerOptions = {
            threshold: 0.5
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.querySelectorAll('.skill-progress').forEach(bar => {
                        bar.style.width = bar.style.width;
                    });
                }
            });
        }, observerOptions);

        document.querySelectorAll('#skills').forEach(section => {
            observer.observe(section);
        });
    </script>
</body>
</html>