@{
    var nd = ViewData["NguoiDung"] as QLTaiChinh.Data.NguoiDung;
}
<nav class="navbar p-0 fixed-top d-flex flex-row">
    <div class="navbar-brand-wrapper d-flex d-lg-none align-items-center justify-content-center">
        <a class="navbar-brand brand-logo-mini text-white" href="/">F</a>
    </div>
    <div class="navbar-menu-wrapper flex-grow d-flex align-items-stretch">
        <button class="navbar-toggler navbar-toggler align-self-center" type="button" data-toggle="minimize">
            <span class="mdi mdi-menu"></span>
        </button>
        <ul class="navbar-nav w-100">
            <li class="nav-item w-100">
                <form asp-action="KetQuaTimKiem" asp-controller="GiaoDich" class="nav-link mt-2 mt-md-0 d-none d-lg-flex search"
                     id="searchWrapper" style="position: relative;">

                    <input type="text"
                           id="globalSearchInput"
                           class="form-control"
                           placeholder="Tim kiem giao dich..."
                           autocomplete="off" />

                    <div id="searchDropdown" style="
                        display: none;
                        position: absolute;
                        top: calc(100% + 2px);
                        left: 0;
                        right: 0;
                        background: #1e2130;
                        border: 1px solid #2c2e33;
                        border-radius: 0 0 6px 6px;
                        z-index: 9999;
                        overflow: hidden;
                        box-shadow: 0 10px 30px rgba(0,0,0,0.5);">

                        <div id="searchResults">
                            <div id="searchHint" style="padding: 12px 16px; color: #6c7293; font-size: 13px;">
                                Go de tim theo mo ta hoac danh muc...
                            </div>
                        </div>

                        <div id="searchViewAll" style="display: none; border-top: 1px solid #2c2e33;">
                            <a id="searchViewAllLink" href="#"
                               style="display: block; padding: 10px 16px; color: #4482ff;
                                      font-size: 13px; text-align: center; text-decoration: none;">
                                Xem tat ca ket qua &rarr;
                            </a>
                        </div>
                    </div>
                </form>
            </li>
        </ul>
        <ul class="navbar-nav navbar-nav-right">
            <li class="nav-item dropdown">
                <a class="nav-link" id="profileDropdown" href="#" data-toggle="dropdown">
                    <div class="navbar-profile">
                        <img class="img-xs rounded-circle"
                             src="@(string.IsNullOrEmpty(nd?.AnhDaiDien)
                                        ? "Avatar"
                                        : Url.Content("~/Avatar/" + nd.AnhDaiDien))"
                             alt="">
                        <p class="mb-0 d-none d-sm-block navbar-profile-name">@(nd?.HoTen ?? "Người dùng")</p>
                        <i class="mdi mdi-menu-down d-none d-sm-block"></i>
                    </div>
                </a>
                <div class="dropdown-menu dropdown-menu-right navbar-dropdown preview-list" aria-labelledby="profileDropdown">
                    <h6 class="p-3 mb-0">Hồ sơ cá nhân</h6>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item preview-item" asp-action="Profile" asp-controller="Profile">
                        <div class="preview-thumbnail">
                            <div class="preview-icon bg-dark rounded-circle">
                                <i class="mdi mdi-settings text-success"></i>
                            </div>
                        </div>
                        <div class="preview-item-content">
                            <p class="preview-subject mb-1" >Cài đặt tài khoản</p>
                        </div>
                    </a>
                    <div class="dropdown-divider"></div>
                    <form asp-action="Logout" asp-controller="Profile" method="post" class="dropdown-item preview-item">
                        <div class="preview-thumbnail">
                            <div class="preview-icon bg-dark rounded-circle">
                                <i class="mdi mdi-logout text-danger"></i>
                            </div>
                        </div>
                        <div class="preview-item-content">
                            <button type="submit" class="btn btn-link preview-subject mb-1 p-0 text-white text-decoration-none">Đăng xuất</button>
                        </div>
                    </form>
                </div>
            </li>
        </ul>
        <button class="navbar-toggler navbar-toggler-right d-lg-none align-self-center" type="button" data-toggle="offcanvas">
            <span class="mdi mdi-format-line-spacing"></span>
        </button>
    </div>
</nav>