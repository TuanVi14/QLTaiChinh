@{
    var nd = ViewData["NguoiDung"] as QLTaiChinh.Data.NguoiDung;
}
<nav class="navbar p-0 fixed-top d-flex flex-row">
    <div class="navbar-brand-wrapper d-flex d-lg-none align-items-center justify-content-center">
        <a class="navbar-brand brand-logo-mini text-white" href="/">F</a>
    </div>
    <div class="navbar-menu-wrapper flex-grow d-flex align-items-stretch">
        <button class="navbar-toggler navbar-toggler align-self-center" type="button" data-toggle="minimize">
            <span class="mdi mdi-menu"></span>
        </button>
        <ul class="navbar-nav w-100">
            <li class="nav-item w-100">
                <div class="nav-link mt-2 mt-md-0 d-none d-lg-flex search"
                     id="searchWrapper" style="position: relative;">

                    <input type="text"
                           id="globalSearchInput"
                           class="form-control"
                           placeholder="Tim kiem giao dich..."
                           autocomplete="off" />

                    <div id="searchDropdown" style="
                        display: none;
                        position: absolute;
                        top: calc(100% + 2px);
                        left: 0;
                        right: 0;
                        background: #1e2130;
                        border: 1px solid #2c2e33;
                        border-radius: 0 0 6px 6px;
                        z-index: 9999;
                        overflow: hidden;
                        box-shadow: 0 10px 30px rgba(0,0,0,0.5);">

                        <div id="searchResults">
                            <div id="searchHint" style="padding: 12px 16px; color: #6c7293; font-size: 13px;">
                                Go de tim theo mo ta hoac danh muc...
                            </div>
                        </div>

                        <div id="searchViewAll" style="display: none; border-top: 1px solid #2c2e33;">
                            <a id="searchViewAllLink" href="#"
                               style="display: block; padding: 10px 16px; color: #4482ff;
                                      font-size: 13px; text-align: center; text-decoration: none;">
                                Xem tat ca ket qua &rarr;
                            </a>
                        </div>
                    </div>
                </div>>
            </li>
        </ul>
        <ul class="navbar-nav navbar-nav-right">
            <li class="nav-item dropdown">
                <a class="nav-link" id="profileDropdown" href="#" data-toggle="dropdown">
                    <div class="navbar-profile">
                        <img class="img-xs rounded-circle"
                             src="@(string.IsNullOrEmpty(nd?.AnhDaiDien)
                                        ? "Avatar"
                                        : Url.Content("~/Avatar/" + nd.AnhDaiDien))"
                             alt="">
                        <p class="mb-0 d-none d-sm-block navbar-profile-name">@(nd?.HoTen ?? "Người dùng")</p>
                        <i class="mdi mdi-menu-down d-none d-sm-block"></i>
                    </div>
                </a>
                <div class="dropdown-menu dropdown-menu-right navbar-dropdown preview-list" aria-labelledby="profileDropdown">
                    <h6 class="p-3 mb-0">Hồ sơ cá nhân</h6>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item preview-item" asp-action="Profile" asp-controller="Profile">
                        <div class="preview-thumbnail">
                            <div class="preview-icon bg-dark rounded-circle">
                                <i class="mdi mdi-settings text-success"></i>
                            </div>
                        </div>
                        <div class="preview-item-content">
                            <p class="preview-subject mb-1" >Cài đặt tài khoản</p>
                        </div>
                    </a>
                    <div class="dropdown-divider"></div>
                    <form asp-action="Logout" asp-controller="Profile" method="post" class="dropdown-item preview-item">
                        <div class="preview-thumbnail">
                            <div class="preview-icon bg-dark rounded-circle">
                                <i class="mdi mdi-logout text-danger"></i>
                            </div>
                        </div>
                        <div class="preview-item-content">
                            <button type="submit" class="btn btn-link preview-subject mb-1 p-0 text-white text-decoration-none">Đăng xuất</button>
                        </div>
                    </form>
                </div>
            </li>
        </ul>
        <button class="navbar-toggler navbar-toggler-right d-lg-none align-self-center" type="button" data-toggle="offcanvas">
            <span class="mdi mdi-format-line-spacing"></span>
        </button>
    </div>
</nav>

<script>
    (function () {
        var input       = document.getElementById('globalSearchInput');
        var dropdown    = document.getElementById('searchDropdown');
        var resultsDiv  = document.getElementById('searchResults');
        var viewAllDiv  = document.getElementById('searchViewAll');
        var viewAllLink = document.getElementById('searchViewAllLink');
        var timer       = null;

        function vnd(n) {
            return new Intl.NumberFormat('vi-VN').format(n) + ' \u20ab';
        }

        function highlight(text, q) {
            var safe = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            return text.replace(
                new RegExp('(' + safe + ')', 'gi'),
                '<mark style="background:#4482ff44;color:#7eb3ff;border-radius:2px;padding:0 2px;">$1</mark>'
            );
        }

        function showHint(msg, color) {
            color = color || '#6c7293';
            resultsDiv.innerHTML =
                '<div style="padding:12px 16px;color:' + color + ';font-size:13px;">' + msg + '</div>';
            viewAllDiv.style.display = 'none';
        }

        function doSearch(q) {
            if (!q) {
                showHint('Gõ để tìm theo mô tả hoặc danh mục...');
                return;
            }

            showHint('Đang tìm...');

            fetch('/GiaoDich/SearchSuggest?q=' + encodeURIComponent(q))
                .then(function (r) {
                    if (!r.ok) throw new Error('HTTP ' + r.status);
                    return r.json();
                })
                .then(function (json) {
                    if (!json.success || json.data.length === 0) {
                        showHint('Không tìm thấy kết quả nào');
                        return;
                    }

                    var html = '';
                    json.data.forEach(function (item) {
                        var isThu = item.loai === 'Thu';
                        var color = isThu ? '#00d25b' : '#fc424a';
                        var icon  = isThu ? 'mdi-arrow-down-circle' : 'mdi-arrow-up-circle';
                        var sign  = isThu ? '+' : '-';

                        html +=
                            '<a href="/GiaoDich/KetQuaTimKiem?q=' + encodeURIComponent(q) + '" ' +
                            'style="display:flex;align-items:center;padding:10px 16px;text-decoration:none;' +
                            'border-bottom:1px solid #2c2e33;transition:background .15s;" ' +
                            'onmouseover="this.style.background=\'#252836\'" ' +
                            'onmouseout="this.style.background=\'transparent\'">' +

                            '<i class="mdi ' + icon + '" style="color:' + color + ';font-size:22px;' +
                            'margin-right:12px;flex-shrink:0;"></i>' +

                            '<div style="flex:1;min-width:0;">' +
                                '<div style="color:#fff;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' +
                                    highlight(item.moTa, q) +
                                '</div>' +
                                '<div style="color:#6c7293;font-size:11px;margin-top:3px;">' +
                                    '<span style="background:#2c2e33;border-radius:3px;padding:1px 7px;">' +
                                        highlight(item.danhMuc, q) +
                                    '</span>&nbsp; ' + item.ngay +
                                '</div>' +
                            '</div>' +

                            '<div style="color:' + color + ';font-size:13px;font-weight:600;' +
                            'margin-left:12px;flex-shrink:0;">' +
                                sign + vnd(item.soTien) +
                            '</div>' +
                            '</a>';
                    });

                    resultsDiv.innerHTML = html;
                    viewAllLink.href = '/GiaoDich/KetQuaTimKiem?q=' + encodeURIComponent(q);
                    viewAllDiv.style.display = 'block';
                })
                .catch(function (err) {
                    showHint('Lỗi kết nối: ' + err.message, '#fc424a');
                });
        }

        // Mở dropdown khi focus vào ô tìm kiếm
        input.addEventListener('focus', function () {
            dropdown.style.display = 'block';
        });

        // Debounce 280ms khi gõ
        input.addEventListener('input', function () {
            clearTimeout(timer);
            var q = this.value.trim();
            timer = setTimeout(function () { doSearch(q); }, 280);
        });

        // Enter → chuyển trang kết quả
        input.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                var q = this.value.trim();
                if (q) window.location.href = '/GiaoDich/KetQuaTimKiem?q=' + encodeURIComponent(q);
            }
            if (e.key === 'Escape') {
                dropdown.style.display = 'none';
                this.blur();
            }
        });

        // Click ra ngoài → đóng dropdown
        document.addEventListener('click', function (e) {
            if (!e.target.closest('#searchWrapper')) {
                dropdown.style.display = 'none';
            }
        });
    })();
</script>