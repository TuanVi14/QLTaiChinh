@* Views/NganSach/Edit.cshtml *@
@model QLTaiChinh.Data.NganSach
@{
    ViewData["Title"] = "Sửa ngân sách";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Dùng lại form Create với isEdit = true *@
@{
    bool isEdit = true;
    string formAction = $"/NganSach/Edit/{Model.NganSachId}";
}

<style>
    .form-card {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 12px;
        padding: 28px;
        max-width: 520px;
    }

    .form-label {
        font-size: .8rem;
        color: #8b949e;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 6px;
        display: block;
    }

    .form-control, .form-select {
        background: #21262d !important;
        border: 1px solid #30363d !important;
        color: #e6edf3 !important;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: .9rem;
        width: 100%;
        outline: none;
    }

        .form-control:focus {
            border-color: #0090e7 !important;
            box-shadow: none !important;
        }

    .row-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .btn-submit {
        background: #0090e7;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 11px 28px;
        font-size: .9rem;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-cancel {
        background: #21262d;
        color: #8b949e;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 11px 20px;
        font-size: .9rem;
        text-decoration: none;
        margin-left: 8px;
    }

    .hint {
        font-size: .75rem;
        color: #8b949e;
        margin-top: 4px;
    }

    .info-box {
        background: #21262d;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 18px;
        font-size: .85rem;
        color: #8b949e;
    }

        .info-box strong {
            color: #e6edf3;
        }
</style>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
    <h4 style="margin:0;font-weight:700;color:#fff">✏️ Sửa ngân sách</h4>
    <a href="/NganSach/NganSach" style="color:#8b949e;text-decoration:none;font-size:.88rem">← Quay lại</a>
</div>

<div class="form-card">
    <div class="info-box">
        📂 Danh mục: <strong>@Model.DanhMuc?.TenDanhMuc</strong> &nbsp;|&nbsp;
        📅 Tháng: <strong>@Model.Thang/@Model.Nam</strong> &nbsp;|&nbsp;
        💰 Đã chi: <strong style="color:#f78166">@Model.SoTienDaChiTieu.ToString("N0") ₫</strong>
    </div>

    <form method="post" action="@formAction">
        @Html.AntiForgeryToken()
        <input type="hidden" name="DanhMucId" value="@Model.DanhMucId" />
        <input type="hidden" name="Thang" value="@Model.Thang" />
        <input type="hidden" name="Nam" value="@Model.Nam" />

        <div class="form-group">
            <label class="form-label">Số tiền giới hạn mới (₫) <span style="color:#f78166">*</span></label>
            <input type="number" name="SoTienGioiHan" class="form-control"
                   value="@Model.SoTienGioiHan" min="1000" step="10000" required />
            <p class="hint">Đã chi tiêu @Model.SoTienDaChiTieu.ToString("N0") ₫ trong tháng này.</p>
        </div>

        <div style="margin-top:24px">
            <button type="submit" class="btn-submit"><i class="mdi mdi-content-save"></i> Lưu thay đổi</button>
            <a href="/NganSach/NganSach" class="btn-cancel">Huỷ</a>
        </div>
    </form>
</div>


